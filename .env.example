# Manifold — environment config

# PostgreSQL
# For docker-compose.yml (external DB): set PG_HOST to your DB server
# For docker-compose.postgres.yml (self-contained): PG_HOST is ignored (hardcoded to 'postgres')
PG_HOST=your-db-host
PG_PORT=5432
PG_USER=manifold
PG_PASS=changeme
PG_DB=manifold

# Host networking — set to the IP/hostname clients use to reach Manifold
MANIFOLD_HOST=your-server-ip
MANIFOLD_PORT=40000
BRIDGE_HOST=your-server-ip
BRIDGE_PORT=8080

# VPN (optional — requires Gluetun)
# VPN_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WG_PRIVATE_KEY=your-wireguard-private-key
# WG_ADDRESSES=10.x.x.x/32
# VPN_CITIES=New York NY
# VPN_CONTROL_USER=admin
# VPN_CONTROL_PASS=changeme

# Optional: override log/data paths
# LOG_PATH=./logs
# DATA_PATH=./data
